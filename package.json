{
  "name": "pirnav-task-management-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace scripts for the PIRNAV task management app",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd backend && npm run dev",
    "dev:client": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm run start",
    "reset:default-user": "cd backend && npm run reset:default-user"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
